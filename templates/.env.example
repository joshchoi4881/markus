# Copy to .env and fill in your values
# Then: source .env (or add to your shell profile)

# Required
DROPSPACE_API_KEY_MYAPP=ds_live_...
ANTHROPIC_API_KEY=sk-ant-...
FAL_KEY=...

# Google Workspace (for clipper/slideshow templates)
# GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/path/to/credentials.json

# Optional
# STRIPE_SECRET_KEY=sk_live_...
# SUPABASE_ACCESS_TOKEN=sbp_...
# POSTHOG_PERSONAL_API_KEY=phx_...
# SENTRY_ACCESS_TOKEN=sntrys_...
# GH_TOKEN=github_pat_...
# BIRD_AUTH_TOKEN=...
# BIRD_CT0=...

# GA4 (optional)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/adc-credentials.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
